{
  "name": "hualian-reports-worker",
  "main": "worker.js",
  "compatibility_date": "2025-05-02",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hualian-reports-db",
      "database_id": "YOUR_D1_DATABASE_ID_HERE",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "CORS_ORIGIN": "http://localhost:8000",
    "PARENT_BASE_URL": "http://localhost:8000/parent.html",
    "SESSION_DURATION_DAYS": "7"
  }
}
